{
	"name": "@kitlangton/ghui",
	"version": "0.10.0",
	"description": "Terminal UI for GitHub pull requests",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitlangton/ghui.git"
	},
	"bugs": {
		"url": "https://github.com/kitlangton/ghui/issues"
	},
	"homepage": "https://github.com/kitlangton/ghui#readme",
	"keywords": [
		"github",
		"pull-requests",
		"terminal",
		"tui",
		"bun"
	],
	"files": [
		"bin",
		"dist",
		"README.md",
		".env.example",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"bin": {
		"ghui": "bin/ghui.js"
	},
	"scripts": {
		"build:cli": "bun run dev/build-cli.ts",
		"build:npm-packages": "bun run dev/build-npm-packages.ts",
		"build:standalone": "bun run dev/build-standalone.ts",
		"changeset": "npm exec --package @changesets/cli@2.31.0 -- changeset",
		"changeset:status": "npm exec --package @changesets/cli@2.31.0 -- changeset status",
		"changeset:version": "npm exec --package @changesets/cli@2.31.0 -- changeset version",
		"dev": "GHUI_FORCE_FULL_REPAINT_ON_START=1 GHUI_MOTEL_PORT=${GHUI_MOTEL_PORT:-27686} GHUI_DEBUG_LOG=${GHUI_DEBUG_LOG:-/tmp/ghui-debug.log} bun --watch src/index.tsx",
		"dev:mock": "GHUI_FORCE_FULL_REPAINT_ON_START=1 GHUI_MOCK_PR_COUNT=200 GHUI_MOCK_REPO_COUNT=4 bun --watch src/index.tsx",
		"link:fork": "bun run dev/link-fork.ts",
		"start": "bun run src/index.tsx",
		"sync:upstream": "bun run dev/sync-upstream.ts",
		"test": "bun test test",
		"test:keymap": "bun run --cwd=packages/keymap test",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --tsconfig tsconfig.json src/ test/",
		"format": "oxfmt src/ test/ dev/",
		"format:check": "oxfmt --check src/ test/ dev/",
		"package:smoke": "bun run dev/package-smoke.ts",
		"prepublishOnly": "printf '%s\n' 'Publish dist/npm/main, not the source checkout.' && exit 1",
		"prepack": "bun run build:cli"
	},
	"workspaces": [
		".",
		"packages/*"
	],
	"dependencies": {
		"@effect/atom-react": "4.0.0-beta.90",
		"@effect/sql-sqlite-bun": "4.0.0-beta.90",
		"@opentui/core": "0.4.2",
		"@opentui/react": "0.4.2",
		"effect": "4.0.0-beta.90",
		"react": "19.2.7",
		"scheduler": "0.27.0"
	},
	"devDependencies": {
		"@effect/language-service": "0.86.2",
		"@ghui/keymap": "workspace:*",
		"@types/bun": "1.3.14",
		"@types/react": "19.2.17",
		"oxfmt": "0.56.0",
		"oxlint": "1.71.0",
		"typescript": "6.0.3"
	}
}
